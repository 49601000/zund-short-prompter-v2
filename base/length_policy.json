    },
    "custom": {
      "display_name": "カスタム min/max",
      "mode": "target_range",
      "target_total_chars": {
        "min": 1400,
        "max": 1600,
        "unit": "japanese_characters"
      },
      "utterance_count": {
        "min": 12,
        "max": 20
      },
      "per_utterance_chars": {
        "default_min": 60,
        "default_max": 150,
        "frenzy_max": 300
      },
      "custom_allowed": true
    }
  },
  "rules": [
    "ショート動画のテンポ感を最優先する",
    "説明より反応を優先する",
    "1発言1メッセージを徹底する",
    "1発言は短く、一瞬で読める長さにする",
    "1発言は3〜20文字程度を基本とする",
    "長文説明は禁止",
    "短文ラリーで会話を回す",
    "ツッコミと反応の往復を重視する",
    "会話が止まったら論点ずらしで動かす",
    "理解よりテンポを優先してよい",
    "多少雑でも勢いを優先する",
    "字幕を見た瞬間に意味が通る表現を使う",
    "情報より空気感を優先する",
    "最後は雑に流して終わってよい"
  ],
  "fallback": [
    "レンジ下限を下回りそうなら発言回数を増やす",
    "レンジ上限を超えそうなら各発言を短くする",
    "長文化ではなくターン数で調整する"
  ]
}
